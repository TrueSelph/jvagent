{
  "name": "jvmessenger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Embeddable popup chat messenger for jvagent (assistant-ui based).",
  "scripts": {
    "dev": "vite --config vite.app.config.ts",
    "build": "tsc --noEmit && vite build --config vite.app.config.ts && vite build --config vite.loader.config.ts",
    "preview": "vite preview --config vite.app.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.20",
    "@assistant-ui/react-markdown": "^0.14.1",
    "@assistant-ui/styles": "^0.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "radix-ui": "^1.6.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^3.2.4"
  }
}
