[flake8]
max-line-length = 88
extend-ignore = E203, E265, E266, E501, W503, W291, W293, W605, E402, E722, F401, F403, F405, F811, F841, F541, ANN101, ANN102, ANN204, ANN201, ANN001, ANN002, ANN003, ANN202, ANN205, D100, D101, D102, D103, D104, D105, D107, D200, D202, D205, D209, D301, D400, D401, D402, D403, N802, N803, N805, N806, N813, N815, B001, B006, B007, B008, B009, B010, B014, B036, C416, SIM102, SIM105, SIM110, SIM114, SIM401, SIM904, SIM908, SIM113
exclude =
    .git,
    __pycache__,
    .venv,
    .pytest_cache,
    .vscode,
    build,
    dist,
    docs,
    migrations,
    examples
per-file-ignores =
    tests/*: E402
