# jvagent Environment Configuration Template
# This file contains SENSITIVE configuration that should NOT be committed to version control
# 
# IMPORTANT: 
# - Copy this file to .env and fill in your actual values
# - Add .env to .gitignore
# - Non-sensitive configuration should be in app.yaml
# - In production, use secure secret management (environment variables, secret managers, etc.)

# ============================================================================
# SECRETS - DO NOT COMMIT TO VERSION CONTROL
# ============================================================================

# OpenAI API Key (for OpenAI language model actions)
# Required if using OpenAI-based actions
OPENAI_API_KEY=your-openai-api-key-here

# Typesense API Key (for vector store actions)
# Required if using Typesense-based vector store actions
TYPESENSE_API_KEY=your-typesense-api-key-here

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure random string for production use
# This should be a long, random, secure string (at least 32 characters)
# Example: openssl rand -hex 32
JVSPATIAL_JWT_SECRET=your-jwt-secret-key-change-in-production

# Admin Password (CHANGE THIS IN PRODUCTION!)
# This is the password for the initial admin user created during bootstrap
# Must be set to create the admin user
JVAGENT_ADMIN_PASSWORD=your-admin-password-here

# ============================================================================
# OPTIONAL: Override app.yaml defaults (if needed)
# ============================================================================
# Most configuration is now in app.yaml. You can override specific values here
# if needed for local development. Environment variables take precedence over app.yaml.

# Server Configuration Overrides
# JVAGENT_HOST=127.0.0.1
# JVAGENT_PORT=8000
# JVAGENT_TITLE=My Custom API Title
# JVAGENT_DESCRIPTION=My Custom API Description

# Database Configuration Overrides
# JVSPATIAL_DB_TYPE=mongodb
# JVSPATIAL_MONGODB_URI=mongodb://localhost:27017
# JVSPATIAL_MONGODB_DB_NAME=jvagent_db
# JVSPATIAL_DB_PATH=./jvagent_db  # For JSON/SQLite databases

# Logging Configuration Overrides
# JVAGENT_LOG_LEVEL=debug
# JVAGENT_LOGGING_ENABLED=true
# JVAGENT_DB_LOGGING_LEVELS=INTERACTION,ERROR,CRITICAL
# JVAGENT_LOG_DB_TYPE=mongodb
# JVAGENT_LOG_DB_URI=mongodb://localhost:27017
# JVAGENT_LOG_DB_NAME=jvagent_logs

# CORS Configuration Overrides
# JVSPATIAL_CORS_ENABLED=true
# JVSPATIAL_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Development Settings
# JVSPATIAL_DEBUG=false
# JVAGENT_ENVIRONMENT=development



# WHATSAPP 
BASE_URL = 
WHATSAPP_API_URL = 
WHATSAPP_API_KEY = 
WHATSAPP_SESSION = 

TTS_API_KEY = 
STT_API_KEY = 
