{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jvagent.use-case/v1",
  "title": "jvagent Conversation Use Case",
  "description": "Multi-turn conversational scenario for orchestrator E2E testing. See .planning/reference/conversation-use-cases.md",
  "type": "object",
  "required": ["schema", "id", "title", "given", "turns"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "jvagent.use-case/v1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9-]*)+$",
      "description": "Stable dot-separated identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "app": {
      "type": "string"
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "array",
          "items": { "type": "string" }
        },
        "docs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "given": { "$ref": "#/$defs/given" },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/turn" }
    },
    "outcome": { "$ref": "#/$defs/assertions" }
  },
  "$defs": {
    "given": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "channel": {
          "type": "string",
          "enum": ["web", "whatsapp", "default"]
        },
        "new_user": { "type": "boolean" },
        "context": {
          "type": "object",
          "additionalProperties": true
        },
        "preconditions": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "fixtures": {
          "type": "object",
          "description": "App extension namespace (e.g. fixtures.stub)",
          "additionalProperties": true
        }
      }
    },
    "turn": {
      "type": "object",
      "required": ["id", "when"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "when": {
          "type": "object",
          "required": ["user"],
          "additionalProperties": false,
          "properties": {
            "user": { "type": "string" }
          }
        },
        "harness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "decisions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/decision" }
            }
          }
        },
        "then": { "$ref": "#/$defs/assertions" }
      }
    },
    "decision": {
      "oneOf": [
        {
          "type": "object",
          "required": ["action", "tool"],
          "additionalProperties": false,
          "properties": {
            "action": { "const": "tool" },
            "tool": { "type": "string" },
            "args": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        {
          "type": "object",
          "required": ["action", "answer"],
          "additionalProperties": false,
          "properties": {
            "action": { "const": "final" },
            "answer": { "type": "string" }
          }
        }
      ]
    },
    "assertions": {
      "type": "object",
      "properties": {
        "task_graph": { "$ref": "#/$defs/taskGraphAssertions" },
        "context": {
          "type": "object",
          "additionalProperties": true
        },
        "session": { "$ref": "#/$defs/sessionAssertions" },
        "publish": { "$ref": "#/$defs/publishAssertions" },
        "tools_surface": { "$ref": "#/$defs/toolsSurfaceAssertions" }
      },
      "additionalProperties": true
    },
    "taskGraphAssertions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pushed": { "type": "string" },
        "not_pushed": { "type": "string" },
        "blocked": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "seed": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "utterance": { "type": "string" },
              "fields": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        },
        "runnable": { "type": "string" }
      }
    },
    "sessionAssertions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interview_type": { "type": "string" },
        "status": { "type": "string" },
        "fields": {
          "type": "object",
          "additionalProperties": true
        },
        "context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "publishAssertions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matches": { "type": "string" }
      }
    },
    "toolsSurfaceAssertions": {
      "type": "object",
      "required": ["includes"],
      "additionalProperties": false,
      "properties": {
        "call_index": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "includes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    }
  }
}
