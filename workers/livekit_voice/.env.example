# LiveKit Cloud (required)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Speech providers (required)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# jvagent Orchestrator (required after deploy — point at your jvagent host)
JVAGENT_BASE_URL=https://your-jvagent-host.example.com

# Fallback when job dispatch metadata omits agent id (optional)
JVAGENT_AGENT_ID=n.Agent.your_agent_id

# Worker registration name — must match LiveKitWhatsAppAction.agent_name in jvagent
JVAGENT_VOICE_AGENT_NAME=jvagent-voice

# Optional tuning
# DEEPGRAM_STT_MODEL=nova-3
# ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
# ELEVENLABS_VOICE_ID=

# Legacy URL fallbacks (optional; JVAGENT_BASE_URL is preferred)
# JVAGENT_INTERNAL_BASE_URL=
# JVAGENT_PUBLIC_BASE_URL=
