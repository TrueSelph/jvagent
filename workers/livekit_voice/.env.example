# LiveKit Cloud (required)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Speech providers (required)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Worker registration name — must match LiveKitWhatsAppAction.agent_name in jvagent.
# Startup-only value: it registers the worker with LiveKit before any call exists.
JVAGENT_VOICE_AGENT_NAME=jvagent-voice

# NOTE: the jvagent host and agent id are NOT configured here.
# Each jvagent instance sends jvagent_base_url + jvagent_agent_id per call in
# LiveKit dispatch metadata. A call missing either is rejected (see logs).

# Optional tuning
# DEEPGRAM_STT_MODEL=nova-3
# ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
# ELEVENLABS_VOICE_ID=
