# jvagent Application .gitignore

# ============================================================================
# Environment and Configuration
# ============================================================================
.env
.env.local
.env.*.local
*.env

# ============================================================================
# Database Files
# ============================================================================
jvdb/
*.db
*.sqlite
*.sqlite3
jvspatial_logs/
jvagent_logs/
jvagent_db/
pageindex_db/
pageindex

# ============================================================================
# File Storage
# ============================================================================
.files/
files/
storage/
uploads/

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
ENV/
env/
.venv

# ============================================================================
# IDE and Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Logs
# ============================================================================
*.log
logs/
*.log.*

# ============================================================================
# Testing
# ============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
tmp/
temp/

# ============================================================================
# OS Files
# ============================================================================
Thumbs.db
.DS_Store
.claude
.cursor

# ============================================================================
# Action and Agent Specific
# ============================================================================
# Ignore compiled action modules
actions/*/__pycache__/
actions/*/*.pyc

# Ignore agent runtime data
agents/*/data/
agents/*/cache/
