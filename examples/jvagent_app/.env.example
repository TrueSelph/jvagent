# jvagent Demo App Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# Server Configuration
# ============================================================================
JVAGENT_HOST=127.0.0.1
JVAGENT_PORT=8000
JVAGENT_TITLE=jvagent Demo App API
JVAGENT_DESCRIPTION=API for jvagent Demo App
JVAGENT_LOG_LEVEL=INFO

# Environment mode: development or production
# In production, observability metrics and debugging data are excluded from API responses
JVAGENT_ENVIRONMENT=development

# ============================================================================
# Database Configuration (Main Application Database)
# ============================================================================
# Database type: json, mongodb, sqlite, or dynamodb
JVSPATIAL_DB_TYPE=json

# Database path (for json/sqlite)
# Default: ./jvagent_db
# In production, use an absolute path appropriate for your deployment
JVSPATIAL_DB_PATH=./jvagent_db

# For JSON databases, also set this to ensure DatabaseManager uses the correct path
JVSPATIAL_JSONDB_PATH=./jvagent_db

# MongoDB Configuration (if using mongodb)
# JVSPATIAL_MONGODB_URI=mongodb://localhost:27017
# JVSPATIAL_MONGODB_DB_NAME=jvagent_db

# SQLite Configuration (if using sqlite)
# JVSPATIAL_SQLITE_PATH=./jvagent_db/sqlite/jvspatial.db

# ============================================================================
# CORS Configuration
# ============================================================================
# CORS origins (comma-separated)
#JVSPATIAL_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://localhost:5173

# ============================================================================
# Database Logging Configuration (jvspatial)
# ============================================================================
# Enable/disable database logging (default: true)
# When enabled, ERROR and CRITICAL logs are automatically saved to a separate database
JVSPATIAL_DB_LOGGING_ENABLED=true

# Log levels to capture (comma-separated) (default: "ERROR,CRITICAL")
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Example: JVSPATIAL_DB_LOGGING_LEVELS=WARNING,ERROR,CRITICAL
JVSPATIAL_DB_LOGGING_LEVELS=INTERACTION,ERROR,CRITICAL

# Logging database name (default: "logs")
# This is the name used to register the logging database in the database manager
JVSPATIAL_DB_LOGGING_DB_NAME=jvspatial_logs

# Enable/disable logging API endpoints (default: true)
# When enabled, provides endpoints to query logs via REST API
JVSPATIAL_DB_LOGGING_API_ENABLED=true

# Logging database type (default: same as JVSPATIAL_DB_TYPE)
# Options: json, sqlite, mongodb, dynamodb
# If not set, uses the same type as the prime database
# JVSPATIAL_LOG_DB_TYPE=json

# Logging database path for JSON/SQLite (default: "./jvspatial_logs")
# For JSON: base directory path
# For SQLite: full path to .db file
JVSPATIAL_LOG_DB_PATH=./jvspatial_logs

# MongoDB Logging Database (if using mongodb for logs)
# JVSPATIAL_LOG_DB_URI=mongodb://localhost:27017
# JVSPATIAL_LOG_DB_NAME=jvspatial_logs

# DynamoDB Logging Database (if using dynamodb for logs)
# JVSPATIAL_LOG_DB_TABLE_NAME=jvspatial_logs
# JVSPATIAL_LOG_DB_REGION=us-east-1
# JVSPATIAL_LOG_DB_ENDPOINT_URL=http://localhost:8000

# ============================================================================
# Authentication Configuration
# ============================================================================
# Enable authentication (default: true)
JVAGENT_AUTH_ENABLED=true
JVSPATIAL_JWT_AUTH_ENABLED=true

# JWT Secret Key (MUST be changed in production)
# Use a strong, random secret key in production
JVSPATIAL_JWT_SECRET=jvagent-demo-secret-key-change-in-production

# JWT expiration time in minutes (default: 60)
JVSPATIAL_JWT_EXPIRE_MINUTES=60

# ============================================================================
# Admin User Configuration
# ============================================================================
# Admin user password (REQUIRED - set this before first run)
# This password will be used for the default admin user
JVAGENT_ADMIN_PASSWORD=change-me-in-production

# Admin user email (default: admin@jvagent.example)
# JVAGENT_ADMIN_EMAIL=admin@jvagent.example

# ============================================================================
# File Storage Configuration
# ============================================================================
# File storage provider: local or s3
JVSPATIAL_FILE_INTERFACE=local

# Root path for file storage (default: .files)
# In production, use an absolute path appropriate for your deployment
JVSPATIAL_FILES_ROOT_PATH=.files

# S3 Configuration (if using s3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# JVSPATIAL_S3_BUCKET_NAME=your-bucket-name
# JVSPATIAL_S3_REGION=us-east-1

# ============================================================================
# Graph Endpoint Configuration
# ============================================================================
# Enable graph endpoint (default: false)
# JVSPATIAL_GRAPH_ENDPOINT_ENABLED=false

# ============================================================================
# External API Keys (for actions)
# ============================================================================
# OpenAI API Key (for openai_lm action)
# Required if using actions that require OpenAI API
# OPENAI_API_KEY=your-openai-api-key

# Add other API keys as needed for your actions
