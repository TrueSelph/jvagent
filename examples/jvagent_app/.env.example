# jvagent Environment Configuration Template
# This file contains SENSITIVE configuration that should NOT be committed to version control
# 
# IMPORTANT: 
# - Copy this file to .env and fill in your actual values
# - Add .env to .gitignore
# - Non-sensitive configuration should be in app.yaml
# - In production, use secure secret management (environment variables, secret managers, etc.)

# ============================================================================
# SECRETS - DO NOT COMMIT TO VERSION CONTROL
# ============================================================================

# OpenAI API Key (for OpenAI language model actions)
# Required if using OpenAI-based actions
OPENAI_API_KEY=your-openai-api-key-here

# Typesense API Key (for vector store actions)
# Required if using Typesense-based vector store actions
TYPESENSE_API_KEY=your-typesense-api-key-here

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure random string for production use
# This should be a long, random, secure string (at least 32 characters)
# Example: openssl rand -hex 32
JVSPATIAL_JWT_SECRET=your-jwt-secret-key-change-in-production

# Admin Password (CHANGE THIS IN PRODUCTION!)
# This is the password for the initial admin user created during bootstrap
# Must be set to create the admin user
JVAGENT_ADMIN_PASSWORD=your-admin-password-here

# ============================================================================
# OPTIONAL: Override app.yaml defaults (if needed)
# ============================================================================
# Most configuration is now in app.yaml. You can override specific values here
# if needed for local development. Environment variables take precedence over app.yaml.

# Server Configuration Overrides
# JVAGENT_HOST=127.0.0.1
# JVAGENT_PORT=8000
# JVAGENT_TITLE=My Custom API Title
# JVAGENT_DESCRIPTION=My Custom API Description

# Application Base URL
# The public URL where this jvagent application is accessible
# Used by WhatsApp and other integrations for webhook URL generation
# Example: https://your-app.example.com or http://localhost:8000 for local development
# APP_BASE_URL=https://your-app.example.com

# Database Configuration Overrides
# JVSPATIAL_DB_TYPE=mongodb
# JVSPATIAL_MONGODB_URI=mongodb://localhost:27017
# JVSPATIAL_MONGODB_DB_NAME=jvagent_db
# JVSPATIAL_DB_PATH=./jvagent_db  # For JSON/SQLite databases

# Logging Configuration Overrides
# JVAGENT_LOG_LEVEL=debug
# JVAGENT_LOGGING_ENABLED=true
# JVAGENT_DB_LOGGING_LEVELS=INTERACTION,ERROR,CRITICAL
# JVAGENT_LOG_DB_TYPE=mongodb
# JVAGENT_LOG_DB_URI=mongodb://localhost:27017
# JVAGENT_LOG_DB_NAME=jvagent_logs

# CORS Configuration Overrides
# JVSPATIAL_CORS_ENABLED=true
# JVSPATIAL_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Development Settings
# JVSPATIAL_DEBUG=false
# JVAGENT_ENVIRONMENT=development

# ============================================================================
# OPTIONAL: External Service Integrations
# ============================================================================
# Configure third-party service integrations for messaging and voice capabilities

# WhatsApp Integration
# Connect to WhatsApp Business API for messaging capabilities
# Requires a WhatsApp Business account and API access

# WhatsApp API endpoint URL (the WhatsApp provider's API, e.g., WPPConnect, WWebJS)
# WHATSAPP_API_URL=http://your-whatsapp-provider:21000

# WhatsApp API authentication key
# WHATSAPP_API_KEY=your-whatsapp-api-key-here

# WhatsApp session identifier for maintaining connection state
# WHATSAPP_SESSION=your-session-id-here

# Text-to-Speech (TTS) Integration
# API key for text-to-speech service (e.g., ElevenLabs, Google TTS, Azure)
# TTS_API_KEY=your-tts-api-key-here

# Speech-to-Text (STT) Integration
# API key for speech-to-text service (e.g., Whisper, Google STT, Azure)
# STT_API_KEY=your-stt-api-key-here

# ============================================================================
# PERFORMANCE OPTIMIZATION
# ============================================================================
# Configure caching and profiling for performance optimization

# Request Profiling
# Enable detailed latency profiling for debugging performance issues
# When enabled, profiles are logged at DEBUG level with latency breakdowns
# Default: false
# JVAGENT_ENABLE_PROFILING=false

# Agent Caching (enabled by default)
# Cache Agent nodes to reduce database lookups
# JVAGENT_ENABLE_AGENT_CACHING=true
# JVAGENT_AGENT_CACHE_TTL=300

# Action Caching
# Cache InteractAction instances to reduce database queries during action discovery
# Automatically invalidated when actions are registered/deregistered
# Default: true
# JVAGENT_ENABLE_ACTION_CACHE=true

# Action cache TTL in seconds
# How long cached actions remain valid before refetching from database
# Default: 60 seconds
# JVAGENT_ACTION_CACHE_TTL=60

# DSPy Response Caching
# Cache DSPy LM responses for deterministic queries
# Disabled by default as it may return stale responses for dynamic queries
# Enable for development/testing or when deterministic responses are desired
# Default: false
# JVAGENT_ENABLE_DSPY_CACHE=false

# Deferred Saves (jvspatial)
# Batch multiple save() calls into a single database write for entities
# that experience rapid updates (e.g., Conversation, Interaction during processing)
# When enabled, save() marks entities as dirty; flush() performs the actual write
# Default: true
# JVSPATIAL_ENABLE_DEFERRED_SAVES=true
