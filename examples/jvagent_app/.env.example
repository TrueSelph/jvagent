# jvagent Application Configuration
# Copy this file to .env and update with your values

# ============================================================================
# Application Settings
# ============================================================================
# Application name
JVAGENT_APP_NAME=jvagent_demo_app

# Application version
JVAGENT_APP_VERSION=1.0.0

# ============================================================================
# Paths
# ============================================================================
# Path to actions directory (relative to app folder or absolute)
JVAGENT_ACTIONS_PATH=./actions

# Path to agents directory (relative to app folder or absolute)
JVAGENT_AGENTS_PATH=./agents

# ============================================================================
# jvspatial Database Configuration
# ============================================================================
# Database path (JSON database)
JVSPATIAL_DB_PATH=./jvdb

# Database provider (json, mongodb)
JVSPATIAL_DB_PROVIDER=json

# MongoDB connection string (if using MongoDB)
# JVSPATIAL_MONGODB_URI=mongodb://localhost:27017/jvagent

# ============================================================================
# File Storage Configuration
# ============================================================================
# File storage provider (local, s3)
JVSPATIAL_FILE_INTERFACE=local

# Root path for local file storage
JVSPATIAL_FILES_ROOT_PATH=./.files

# S3 Configuration (if using S3)
# JVSPATIAL_S3_BUCKET=my-bucket
# JVSPATIAL_S3_REGION=us-east-1
# JVSPATIAL_S3_ACCESS_KEY=your-access-key
# JVSPATIAL_S3_SECRET_KEY=your-secret-key

# ============================================================================
# Server Configuration
# ============================================================================
# Server host
JVSPATIAL_HOST=0.0.0.0

# Server port
JVSPATIAL_PORT=8000

# API prefix
JVSPATIAL_API_PREFIX=/api

# ============================================================================
# Authentication Configuration
# ============================================================================
# Enable authentication
JVSPATIAL_AUTH_ENABLED=true

# JWT secret key (generate a secure random string)
JVSPATIAL_JWT_SECRET=your-secret-key-change-this-in-production

# JWT algorithm
JVSPATIAL_JWT_ALGORITHM=HS256

# JWT expiration (in seconds)
JVSPATIAL_JWT_EXPIRATION=3600

# ============================================================================
# Admin User Configuration
# ============================================================================
# Admin username
JVAGENT_ADMIN_USERNAME=admin

# Admin email
JVAGENT_ADMIN_EMAIL=admin@jvagent.example

# Admin password (change this in production!)
JVAGENT_ADMIN_PASSWORD=admin123

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
JVSPATIAL_LOG_LEVEL=INFO

# ============================================================================
# Development Settings
# ============================================================================
# Enable debug mode
JVSPATIAL_DEBUG=false

# Enable CORS (for development)
JVSPATIAL_CORS_ENABLED=true

# CORS origins (comma-separated)
JVSPATIAL_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
